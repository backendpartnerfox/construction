# Copy to .env for local dev, or set these in the Render dashboard for production.

# --- Runtime ---
NODE_ENV=production        # 'development' locally
PORT=9000                  # Render will inject its own PORT — this only matters locally

# --- Database (PostgreSQL) ---
DB_HOST=ep-xxx.neon.tech   # from Neon "Connection Details"
DB_USER=postgres
DB_PORT=5432
DB_PASSWORD=your_password
DB_NAME=constructions
DB_SCHEMA=public

# --- Auth ---
JWT_SECRET=long_random_string_here

# --- CORS: comma-separated list of production frontend origins ---
ALLOWED_ORIGINS=https://your-app.netlify.app

# --- Razorpay (optional) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
