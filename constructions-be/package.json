{
    "dependencies": {
        "bcryptjs": "^3.0.2",
        "body-parser": "^1.20.3",
        "cors": "^2.8.5",
        "dotenv": "^16.5.0",
        "express": "^4.21.2",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.2",
        "pg": "^8.16.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1"
    },
    "name": "pf_new",
    "version": "1.0.0",
    "main": "server.js",
    "engines": {
        "node": ">=14.0.0"
    },
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "dev:test": "PORT=3001 nodemon server.js",
        "test:setup": "node tests/setup/createTestDb.js && node tests/setup/setupTestDb.js",
        "test": "npm run test:setup && cross-env NODE_ENV=test jest --testTimeout=30000 --forceExit",
        "test:watch": "cross-env NODE_ENV=test jest --watch --testTimeout=30000",
        "test:coverage": "npm run test:setup && cross-env NODE_ENV=test jest --coverage --testTimeout=30000",
        "test:port": "cross-env NODE_ENV=test PORT=3002 jest --testTimeout=30000",
        "test:all": "node tests/run-all-tests.js",
        "test:clients": "cross-env NODE_ENV=test jest tests/clients_route.test.js --testTimeout=30000 --forceExit",
        "test:projects": "cross-env NODE_ENV=test jest tests/projects_route.test.js --testTimeout=30000 --forceExit",
        "test:items": "cross-env NODE_ENV=test jest tests/items_route.test.js --testTimeout=30000 --forceExit",
        "test:employees": "cross-env NODE_ENV=test jest tests/employees_route.test.js --testTimeout=30000 --forceExit",
        "dev:all": "concurrently \"npm run dev\" \"npm run test:watch\"",
        "dev:split": "concurrently \"PORT=3001 npm run dev\" \"npm run test:watch\""
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "devDependencies": {
        "allure-commandline": "^2.34.1",
        "allure-js-commons": "^3.3.0",
        "concurrently": "^8.2.2",
        "cross-env": "^7.0.3",
        "jest": "^29.7.0",
        "jest-allure": "^0.1.3",
        "jest-html-reporter": "^4.3.0",
        "jest-stare": "^2.5.2",
        "nodemon": "^3.1.10",
        "supertest": "^7.1.0",
        "xlsx": "^0.18.5"
    }
}
